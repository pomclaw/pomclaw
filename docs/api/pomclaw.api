syntax = "v1"

import "skill.api"
import "tools.api"
import "traces.api"

info (
	title:   "Pomclaw API"
	desc:    "Pomclaw Multi-Tenant Agent Platform API"
	author:  "Pomclaw Team"
	email:   "support@pomclaw.com"
	version: "v1"
)

// ============ Auth Types ============
type RegisterReq {
	Email    string `json:"email"`
	Password string `json:"password"`
	Username string `json:"username"`
}

type LoginReq {
	Username string `json:"username"`
	Password string `json:"password"`
}

type AuthResp {
	AccessToken  string `json:"access_token"`
	RefreshToken string `json:"refresh_token"`
	UserId       string `json:"user_id"`
	ExpiresIn    int64  `json:"expires_in"`
	TokenType    string `json:"token_type"`
}

type UserResp {
	Id        string `json:"id"`
	Email     string `json:"email"`
	Username  string `json:"username"`
	CreatedAt int64  `json:"created_at"`
}

type RefreshReq {
	RefreshToken string `json:"refresh_token"`
}

type LogoutReq {}

type LogoutResp {}

type GetMeReq {}

type GetMeResp {
	User UserResp `json:"user"`
}

// ============ Agent Types ============
type Agent {
	// Basic fields
	Id          string `json:"id"`
	AgentKey    string `json:"agent_key"`
	DisplayName string `json:"display_name"`
	Frontmatter string `json:"frontmatter,omitempty"`
	OwnerId     string `json:"owner_id"`
	// LLM configuration
	Provider          string `json:"provider"`
	Model             string `json:"model"`
	ContextWindow     int    `json:"context_window"`
	MaxToolIterations int    `json:"max_tool_iterations"`
	// Workspace
	Workspace           string `json:"workspace"`
	RestrictToWorkspace bool   `json:"restrict_to_workspace"`
	// Type and status
	AgentType string `json:"agent_type"`
	IsDefault bool   `json:"is_default"`
	Status    string `json:"status"`
	// JSONB configs
	//    ToolsConfig []byte `json:"tools_config,omitempty"`
	//    MemoryConfig []byte `json:"memory_config,omitempty"`
	//    CompactionConfig []byte `json:"compaction_config,omitempty"`
	//    OtherConfig []byte `json:"other_config,omitempty"`
	// V3 fields
	Emoji            string `json:"emoji,omitempty"`
	AgentDescription string `json:"agent_description,omitempty"`
	ThinkingLevel    string `json:"thinking_level,omitempty"`
	MaxTokens        int    `json:"max_tokens,omitempty"`
	SelfEvolve       bool   `json:"self_evolve,omitempty"`
	SkillEvolve      bool   `json:"skill_evolve,omitempty"`
	// Timestamps
	CreatedAt int64 `json:"created_at"`
	UpdatedAt int64 `json:"updated_at"`
}

type ListAgentsReq {}

type ListAgentsResp {
	Total  int64   `json:"total"`
	Agents []Agent `json:"agents"`
}

type CreateAgentReq {
	AgentKey         string `json:"agent_key"`
	DisplayName      string `json:"display_name"`
	Frontmatter      string `json:"frontmatter,optional"`
	Provider         string `json:"provider,optional"`
	Model            string `json:"model"`
	AgentDescription string `json:"agent_description,optional"`
	// Optional advanced fields
	ContextWindow     int    `json:"context_window,optional"`
	MaxToolIterations int    `json:"max_tool_iterations,optional"`
	Workspace         string `json:"workspace,optional"`
	//    ToolsConfig []byte `json:"tools_config,optional"`
	//    MemoryConfig []byte `json:"memory_config,optional"`
	//    CompactionConfig []byte `json:"compaction_config,optional"`
	//    OtherConfig []byte `json:"other_config,optional"`
	// V3 fields
	Emoji         string `json:"emoji,optional"`
	ThinkingLevel string `json:"thinking_level,optional"`
	MaxTokens     int    `json:"max_tokens,optional"`
	SelfEvolve    bool   `json:"self_evolve,optional"`
	SkillEvolve   bool   `json:"skill_evolve,optional"`
}

type CreateAgentResp {
	Agent Agent `json:"agent"`
}

type GetAgentReq {
	AgentId string `path:"agent_id"`
}

type GetAgentResp {
	Agent Agent `json:"agent"`
}

type UpdateAgentReq {
	AgentId string `path:"agent_id"`
	// All fields are optional for partial updates
	AgentKey          string `json:"agent_key,optional"`
	DisplayName       string `json:"display_name,optional"`
	Frontmatter       string `json:"frontmatter,optional"`
	Provider          string `json:"provider,optional"`
	Model             string `json:"model,optional"`
	Status            string `json:"status,optional"`
	ContextWindow     int    `json:"context_window,optional"`
	MaxToolIterations int    `json:"max_tool_iterations,optional"`
	Workspace         string `json:"workspace,optional"`
	//    ToolsConfig []byte `json:"tools_config,optional"`
	//    MemoryConfig []byte `json:"memory_config,optional"`
	//    CompactionConfig []byte `json:"compaction_config,optional"`
	//    OtherConfig []byte `json:"other_config,optional"`
	AgentDescription string `json:"agent_description,optional"`
	Emoji            string `json:"emoji,optional"`
	ThinkingLevel    string `json:"thinking_level,optional"`
	MaxTokens        int    `json:"max_tokens,optional"`
	SelfEvolve       bool   `json:"self_evolve,optional"`
	SkillEvolve      bool   `json:"skill_evolve,optional"`
}

type UpdateAgentResp {
	Agent Agent `json:"agent"`
}

type DeleteAgentReq {
	AgentId string `path:"agent_id"`
}

type DeleteAgentResp {}

// ============ Session Types ============
type Session {
	Id           string `json:"id"`
	AgentId      string `json:"agent_id"`
	Title        string `json:"title"`
	Preview      string `json:"preview"`
	MessageCount int    `json:"message_count"`
	Created      string `json:"created"`
	Updated      string `json:"updated"`
}

type ListSessionsReq {
	AgentId string `form:"agent_id,optional"`
	Offset  int    `form:"offset,optional,default=0"`
	Limit   int    `form:"limit,optional,default=20"`
}

type ListSessionsResp {
	Total    int64     `json:"total"`
	Sessions []Session `json:"sessions"`
}

type CreateSessionReq {
	AgentId string `json:"agent_id"`
	Title   string `json:"title"`
}

type CreateSessionResp {
	Session Session `json:"session"`
}

type GetSessionReq {
	Id string `path:"id"`
}

type GetSessionResp {
	Session Session `json:"session"`
}

type DeleteSessionReq {
	Id string `path:"id"`
}

type DeleteSessionResp {}

// ============ Provider Types ============
type Provider {
	Id           string `json:"id"`
	Name         string `json:"name"`
	ProviderType string `json:"provider_type"`
	APIBase      string `json:"api_base"`
	APIKey       string `json:"api_key"`
	DisplayName  string `json:"display_name"`
	Enabled      bool   `json:"enabled"`
}

type ListProvidersReq {}

type ListProvidersResp {
	Total     int64      `json:"total"`
	Providers []Provider `json:"providers"`
}

type CreateProviderReq {
	Name         string `json:"name"`
	ProviderType string `json:"provider_type"`
	APIBase      string `json:"api_base"`
	APIKey       string `json:"api_key"`
	DisplayName  string `json:"display_name"`
	Enabled      bool   `json:"enabled"`
}

type CreateProviderResp {
	Provider Provider `json:"provider"`
}

type UpdateProviderReq {
	Id          string `path:"id"`
	Name        string `json:"name,omitempty"`
	APIBase     string `json:"api_base,omitempty"`
	APIKey      string `json:"api_key,omitempty"`
	DisplayName string `json:"display_name,omitempty"`
	Enabled     bool   `json:"enabled,omitempty"`
}

type GetProviderReq {
	Id string `path:"id"`
}

type GetProviderResp {
	Provider Provider `json:"provider"`
}

type UpdateProviderResp {
	Provider Provider `json:"provider"`
}

type DeleteProviderReq {
	Id string `path:"id"`
}

type DeleteProviderResp {}

type ProviderModel {
	Name string `json:"name"`
	Id   string `json:"id"`
}

type ListProviderModelsReq {
	Id string `path:"id"`
}

type ListProviderModelsResp {
	Models []ProviderModel `json:"models"`
}

type VerifyProviderReq {
	Id    string `path:"id"`
	Model string `json:"model"`
}

type VerifyProviderResp {
	Valid bool   `json:"valid"`
	Error string `json:"error,omitempty"`
	Note  string `json:"note,omitempty"`
}

// ============ Usage Analytics Types ============
type UsageTimeSeriesPoint {
	BucketTime    string  `json:"bucket_time"`
	RequestCount  int     `json:"request_count"`
	ErrorCount    int     `json:"error_count"`
	UniqueUsers   int     `json:"unique_users"`
	InputTokens   int64   `json:"input_tokens"`
	OutputTokens  int64   `json:"output_tokens"`
	TotalCost     float64 `json:"total_cost"`
	LLMCallCount  int     `json:"llm_call_count"`
	ToolCallCount int     `json:"tool_call_count"`
	AvgDurationMS int     `json:"avg_duration_ms"`
}

type GetUsageTimeSeriesReq {
	From     string `form:"from"`
	To       string `form:"to"`
	GroupBy  string `form:"group_by,optional,default=hour"`
	AgentID  string `form:"agent_id,optional"`
	Channel  string `form:"channel,optional"`
	Provider string `form:"provider,optional"`
	Model    string `form:"model,optional"`
}

type GetUsageTimeSeriesResp {
	Points []UsageTimeSeriesPoint `json:"points"`
}

type UsageSummary {
	Requests      int     `json:"requests"`
	InputTokens   int64   `json:"input_tokens"`
	OutputTokens  int64   `json:"output_tokens"`
	Cost          float64 `json:"cost"`
	UniqueUsers   int     `json:"unique_users"`
	Errors        int     `json:"errors"`
	LLMCalls      int     `json:"llm_calls"`
	ToolCalls     int     `json:"tool_calls"`
	AvgDurationMS int     `json:"avg_duration_ms"`
}

type GetUsageSummaryReq {
	Period   string `form:"period,optional,default=24h"`
	AgentID  string `form:"agent_id,optional"`
	Channel  string `form:"channel,optional"`
	Provider string `form:"provider,optional"`
	Model    string `form:"model,optional"`
}

type GetUsageSummaryResp {
	Current  UsageSummary `json:"current"`
	Previous UsageSummary `json:"previous"`
}

// ============ System Health Types ============
type SystemHealth {
	Version         string `json:"version"`
	Uptime          int64  `json:"uptime"`
	Database        string `json:"database,omitempty"`
	Tools           int    `json:"tools"`
	Sessions        int    `json:"sessions"`
	Providers       int    `json:"providers"`
	ChannelTotal    int    `json:"channelTotal"`
	ChannelOnline   int    `json:"channelOnline"`
	ChannelDegraded int    `json:"channelDegraded"`
	ChannelFailed   int    `json:"channelFailed"`
}

type GetSystemHealthReq {}

type GetSystemHealthResp {
	Health SystemHealth `json:"health"`
}

@server (
	jwt: Auth
)
service pomclaw {
	// // ============ Auth Endpoints ============
	// @doc "User registration"
	// @handler Register
	// post /v1/auth/register (RegisterReq) returns (AuthResp)
	//
	// @doc "User login"
	// @handler Login
	// post /v1/auth/login (LoginReq) returns (AuthResp)
	//
	// @doc "Get current user info"
	// @handler GetMe
	// get /v1/auth/me (GetMeReq) returns (GetMeResp)
	//
	// @doc "Refresh authentication token"
	// @handler Refresh
	// post /v1/auth/refresh (RefreshReq) returns (AuthResp)
	//
	// @doc "User logout"
	// @handler Logout
	// post /v1/auth/logout (LogoutReq) returns (LogoutResp)
	// ============ Agent Endpoints ============
	@doc "List all agents"
	@handler ListAgents
	get /v1/agents (ListAgentsReq) returns (ListAgentsResp)

	@doc "Create a new agent"
	@handler CreateAgent
	post /v1/agents (CreateAgentReq) returns (CreateAgentResp)

	@doc "Get agent details"
	@handler GetAgent
	get /v1/agents/:agent_id (GetAgentReq) returns (GetAgentResp)

	@doc "Update agent"
	@handler UpdateAgent
	put /v1/agents/:agent_id (UpdateAgentReq) returns (UpdateAgentResp)

	@doc "Delete agent"
	@handler DeleteAgent
	delete /v1/agents/:agent_id (DeleteAgentReq) returns (DeleteAgentResp)

	// ============ Session Endpoints ============
	@doc "List all sessions"
	@handler HandleListSessions
	get /v1/sessions (ListSessionsReq) returns (ListSessionsResp)

	@doc "Create a new session"
	@handler HandleCreateSession
	post /v1/sessions (CreateSessionReq) returns (CreateSessionResp)

	@doc "Get session details"
	@handler HandleGetSession
	get /v1/sessions/:id (GetSessionReq) returns (GetSessionResp)

	@doc "Delete session"
	@handler HandleDeleteSession
	delete /v1/sessions/:id (DeleteSessionReq) returns (DeleteSessionResp)

	// ============ Provider Endpoints ============
	@doc "List all providers"
	@handler ListProviders
	get /v1/providers (ListProvidersReq) returns (ListProvidersResp)

	@doc "Create a new provider"
	@handler CreateProvider
	post /v1/providers (CreateProviderReq) returns (CreateProviderResp)

	@doc "Get provider details"
	@handler GetProvider
	get /v1/providers/:id (GetProviderReq) returns (GetProviderResp)

	@doc "Update provider"
	@handler UpdateProvider
	put /v1/providers/:id (UpdateProviderReq) returns (UpdateProviderResp)

	@doc "Delete provider"
	@handler DeleteProvider
	delete /v1/providers/:id (DeleteProviderReq) returns (DeleteProviderResp)

	@doc "List provider models"
	@handler ListProviderModels
	get /v1/providers/:id/models (ListProviderModelsReq) returns (ListProviderModelsResp)

	@doc "Verify provider"
	@handler VerifyProvider
	post /v1/providers/:id/verify (VerifyProviderReq) returns (VerifyProviderResp)

	// ============ Usage Analytics Endpoints ============
	@doc "Get usage time series"
	@handler GetUsageTimeSeries
	get /v1/usage/timeseries (GetUsageTimeSeriesReq) returns (GetUsageTimeSeriesResp)

	@doc "Get usage summary"
	@handler GetUsageSummary
	get /v1/usage/summary (GetUsageSummaryReq) returns (GetUsageSummaryResp)

	// ============ System Health Endpoints ============
	@doc "Get system health status"
	@handler GetSystemHealth
	get /v1/system/health (GetSystemHealthReq) returns (GetSystemHealthResp)

	//service skills
	@doc "List all skills"
	@handler ListSkills
	get /v1/skills (ListSkillsReq) returns (SkillsResp)

	@doc "Create a new skill"
	@handler CreateSkill
	post /v1/skills (CreateSkillReq) returns (SkillResp)

	@doc "Get skill details"
	@handler GetSkill
	get /v1/skills/:id (GetSkillReq) returns (GetSkillResp)

	@doc "Update skill"
	@handler UpdateSkill
	put /v1/skills/:id (UpdateSkillReq) returns (UpdateSkillResp)

	@doc "Grant skill to agent"
	@handler GrantSkill
	post /v1/skills/:id/grant/:agent_id (GrantSkillReq) returns (GrantStatusResp)

	@doc "Revoke skill from agent"
	@handler RevokeSkill
	delete /v1/skills/:id/revoke/:agent_id (RevokeSkillReq) returns (RevokeStatusResp)

	@doc "List skills for agent with grant status"
	@handler ListAgentSkills
	get /v1/agents/:agent_id/skills (ListAgentSkillsReq) returns (SkillsWithGrantResp)

	//service tools
	@doc "List all built-in tools"
	@handler ListBuiltinTools
	get /v1/tools/builtin (ListBuiltinToolsReq) returns (ListBuiltinToolsResp)

	@doc "Get built-in tool details"
	@handler GetBuiltinTool
	get /v1/tools/builtin/:name (GetBuiltinToolReq) returns (GetBuiltinToolResp)

	@doc "Update built-in tool (enabled, settings)"
	@handler UpdateBuiltinTool
	put /v1/tools/builtin/:name (UpdateBuiltinToolReq) returns (UpdateBuiltinToolResp)

	// ============ Trace Endpoints ============
	@doc "List traces with optional filtering"
	@handler ListTraces
	get /v1/traces (ListTracesReq) returns (ListTracesResp)

	@doc "Get trace details with spans"
	@handler GetTrace
	get /v1/traces/:traceID (GetTraceReq) returns (GetTraceResp)

	@doc "Export trace as gzip-compressed JSON"
	@handler ExportTrace
	get /v1/traces/:traceID/export (ExportTraceReq) returns (ExportTraceResp)

	@doc "Get cost summary by date, agent, model, or provider"
	@handler GetCostSummary
	get /v1/costs/summary (GetCostSummaryReq) returns (GetCostSummaryResp)
}

